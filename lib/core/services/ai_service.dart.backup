import 'dart:async';
import 'dart:convert';
import 'package:attackshield/core/services/risk_engine.dart';
import 'package:http/http.dart' as http;
import 'package:get_storage/get_storage.dart';
import 'package:attackshield/shared/models/models.dart';

/// ────────────────────────────────────────────────────────────────────────────
/// AIService — wraps the Google Gemini API for all AI features.
///
/// API key is stored locally in GetStorage (user-provided in Settings).
/// All calls are non-streaming for simplicity in a mobile context.
///
/// Features:
///   1. explainTechnique()     — plain-English technique explainer
///   2. mapThreatIntelligence()— paste text → ATT&CK technique IDs
///   3. generateCoverageAdvice()— personalized coverage recommendations
///   4. debriefSimulation()    — AI-written simulation debrief
///   5. naturalLanguageSearch()— query → relevant technique IDs
///
/// Rate Limiting:
///   - Automatic retry with exponential backoff (up to 3 attempts)
///   - Request queuing to prevent concurrent API calls
///   - Response caching to avoid duplicate requests
///   - Adaptive request throttling based on API load
/// ────────────────────────────────────────────────────────────────────────────
class AIService {
  static const String _apiKeyStorageKey = 'gemini_api_key';
  static const String _apiBaseUrl =
      'https://generativelanguage.googleapis.com/v1beta/models';
  static const String _model = 'gemini-2.0-flash';

  // Rate limiting & request management
  static const int _maxRetries = 3;
  static const Duration _initialBackoff = Duration(seconds: 2);
  static const Duration _minRequestInterval = Duration(milliseconds: 500);

  static final AIService _instance = AIService._internal();
  factory AIService() => _instance;
  AIService._internal();

  // Simple response cache (techniqueId or query -> response)
  final _responseCache = <String, String>{};
  DateTime _lastRequestTime = DateTime.now();

  // ── API key management ────────────────────────────────────────────────────

  String? get apiKey => GetStorage().read<String>(_apiKeyStorageKey);

  bool get hasApiKey {
    final key = apiKey;
    return key != null && key.trim().isNotEmpty;
  }

  Future<void> saveApiKey(String key) async {
    await GetStorage().write(_apiKeyStorageKey, key.trim());
  }

  Future<void> clearApiKey() async {
    await GetStorage().remove(_apiKeyStorageKey);
  }

  // ── Request queue management ──────────────────────────────────────────────

  // Note: Direct throttling is used instead of queuing for simplicity
  // This ensures minimum interval between requests to respect rate limits

  // ── Throttling helper ─────────────────────────────────────────────────────

  /// Enforce minimum time between requests to avoid rate limting
  Future<void> _throttle() async {
    final elapsed = DateTime.now().difference(_lastRequestTime);
    if (elapsed < _minRequestInterval) {
      await Future.delayed(_minRequestInterval - elapsed);
    }
    _lastRequestTime = DateTime.now();
  }

  // ── Core API call with retry logic ────────────────────────────────────────

  Future<String> _call({
    required String systemPrompt,
    required String userMessage,
    int maxTokens = 1024,
    String? cacheKey,
  }) async {
    // Check cache first
    if (cacheKey != null && _responseCache.containsKey(cacheKey)) {
      return _responseCache[cacheKey]!;
    }

    final key = apiKey;
    if (key == null || key.isEmpty) {
      throw const AIServiceException(
        'No API key configured. Please add your Google Gemini API key in Settings.',
        code: 'no_api_key',
      );
    }

    String? lastError;
    for (int attempt = 0; attempt < _maxRetries; attempt++) {
      try {
        // Throttle requests to respect rate limits
        await _throttle();

        final url = Uri.parse('$_apiBaseUrl/$_model:generateContent?key=$key');

        final response = await http
            .post(
              url,
              headers: {'Content-Type': 'application/json'},
              body: jsonEncode({
                'contents': [
                  {
                    'role': 'user',
                    'parts': [
                      {'text': '$systemPrompt\n\n$userMessage'},
                    ],
                  },
                ],
                'generationConfig': {
                  'maxOutputTokens': maxTokens,
                  'temperature': 1.0,
                },
              }),
            )
            .timeout(const Duration(seconds: 60));

        if (response.statusCode == 200) {
          final data = jsonDecode(response.body);
          final candidates = data['candidates'] as List?;
          if (candidates == null || candidates.isEmpty) {
            throw const AIServiceException('No response from Gemini');
          }
          final content = candidates[0]['content']['parts'] as List?;
          if (content == null || content.isEmpty) {
            throw const AIServiceException('No text content in response');
          }
          final result = (content[0]['text'] as String).trim();

          // Cache successful response
          if (cacheKey != null) {
            _responseCache[cacheKey] = result;
          }

          return result;
        } else if (response.statusCode == 401) {
          throw const AIServiceException(
            'Invalid API key. Please check your Google Gemini API key in Settings.',
            code: 'invalid_key',
          );
        } else if (response.statusCode == 429) {
          // Rate limit — retry with exponential backoff
          lastError = 'Rate limit (429)';
          if (attempt < _maxRetries - 1) {
            final backoffDuration =
                _initialBackoff *
                (1 << attempt); // 2s, 4s, 8s exponential backoff
            await Future.delayed(backoffDuration);
            continue; // Retry
          } else {
            throw AIServiceException(
              'Rate limit exceeded. Please wait a few minutes before trying again. (Attempt $attempt/$_maxRetries)',
              code: 'rate_limit',
            );
          }
        } else if (response.statusCode == 503) {
          // Service unavailable — retry
          lastError = 'Service unavailable (503)';
          if (attempt < _maxRetries - 1) {
            final backoffDuration = _initialBackoff * (1 << attempt);
            await Future.delayed(backoffDuration);
            continue; // Retry
          } else {
            throw AIServiceException(
              'Gemini service temporarily unavailable. Please try again later.',
              code: 'service_unavailable',
            );
          }
        } else if (response.statusCode == 400) {
          final data = jsonDecode(response.body);
          final errorMsg = data['error']?['message'] ?? 'Invalid request';
          throw AIServiceException(
            'Request error: $errorMsg',
            code: 'request_error',
          );
        } else {
          final data = jsonDecode(response.body);
          final errorMsg = data['error']?['message'] ?? 'Unknown API error';
          throw AIServiceException(
            'API error (${response.statusCode}): $errorMsg',
            code: 'api_error',
          );
        }
      } on AIServiceException {
        rethrow;
      } catch (e) {
        lastError = e.toString();
        if (attempt < _maxRetries - 1) {
          final backoffDuration = _initialBackoff * (1 << attempt);
          await Future.delayed(backoffDuration);
          continue;
        } else {
          if (e.toString().contains('SocketException') ||
              e.toString().contains('TimeoutException')) {
            throw const AIServiceException(
              'Network error. Please check your internet connection.',
              code: 'network_error',
            );
          }
          throw AIServiceException(
            'Request failed after $attempt attempts: $lastError',
          );
        }
      }
    }

    throw AIServiceException('Max retries exceeded. Last error: $lastError');
  }

  // ── Feature 1: Technique Explainer ───────────────────────────────────────

  /// Returns a structured plain-English explanation of an ATT&CK technique,
  /// personalised to the organization's sector and technology context.
  Future<TechniqueExplanation> explainTechnique({
    required AttackTechnique technique,
    OrganizationProfile? orgProfile,
  }) async {
    const systemPrompt = '''
You are a cybersecurity expert explaining MITRE ATT&CK techniques to both technical and non-technical users.
Your explanations must be clear, concrete, and actionable.
Always respond with valid JSON only — no markdown, no preamble, no code fences.
''';

    final orgContext = orgProfile != null
        ? '''
Organization context:
- Sector: ${orgProfile.sector.label}
- Size: ${orgProfile.orgSize.label}
- Technology: ${orgProfile.techStackItems.map((t) => t.label).join(', ')}
- Controls in place: ${orgProfile.securityControlItems.map((c) => c.label).join(', ')}
'''
        : '';

    final userMessage =
        '''
Explain this MITRE ATT&CK technique to me:

ID: ${technique.id}
Name: ${technique.name}
Tactics: ${technique.tactics.join(', ')}
Platforms: ${technique.platforms.join(', ')}
Description: ${technique.description}
Risk Score: ${technique.riskScore}/10
${orgContext}

Respond with a JSON object with exactly these fields:
{
  "realWorldStory": "A 2-3 sentence concrete story of how this attack happens in real life. Name a real-world breach or incident if relevant.",
  "whatItLooksLike": "What this attack looks like from the defender's perspective. What signals or symptoms appear.",
  "whoUsesIt": "Which threat actors or groups are known to use this technique. Be specific.",
  "checkRightNow": "3-4 specific, actionable things a defender can check RIGHT NOW to see if they have been compromised.",
  "topDefense": "The single most important defensive action to take. One sentence, specific and actionable.",
  "plainSummary": "One sentence explaining this technique to a complete non-technical person.",
  "sectorRelevance": "${orgProfile != null ? 'How specifically relevant is this technique to a ${orgProfile.sector.label} organization?' : 'How commonly is this technique used across industries?'}"
}
''';

    final raw = await _call(
      systemPrompt: systemPrompt,
      userMessage: userMessage,
      maxTokens: 1200,
      cacheKey: 'explain_${technique.id}',
    );

    return TechniqueExplanation.fromJson(jsonDecode(_cleanJson(raw)));
  }

  // ── Feature 2: Threat Intelligence Mapper ────────────────────────────────

  /// Takes any raw text (news article, CVE, advisory, vendor bulletin)
  /// and extracts ATT&CK technique IDs with reasoning.
  Future<ThreatIntelResult> mapThreatIntelligence(String rawText) async {
    const systemPrompt = '''
You are a cyber threat intelligence analyst specializing in MITRE ATT&CK mapping.
Analyse text and identify which ATT&CK techniques are referenced or implied.
Always respond with valid JSON only — no markdown, no preamble, no code fences.
''';

    final userMessage =
        '''
Analyse this threat intelligence text and identify relevant MITRE ATT&CK Enterprise techniques:

---
$rawText
---

Respond with a JSON object with exactly these fields:
{
  "summary": "2-3 sentence summary of the threat described in this text.",
  "threatActor": "Name of the threat actor or group if identifiable, otherwise 'Unknown'.",
  "targetedSectors": ["list", "of", "targeted", "sectors"],
  "mappedTechniques": [
    {
      "techniqueId": "T1566",
      "techniqueName": "Phishing",
      "confidence": "high",
      "evidence": "Specific quote or phrase from the text that maps to this technique."
    }
  ],
  "recommendedActions": ["action1", "action2", "action3"],
  "severityLevel": "Critical|High|Medium|Low",
  "alertTitle": "A short alert title for this threat (max 10 words)"
}

Confidence levels: "high" (explicitly stated), "medium" (strongly implied), "low" (possible based on context).
Only include techniques with at least "low" confidence.
Maximum 10 techniques.
''';

    // Note: Skip caching for threat intel since text varies significantly
    final raw = await _call(
      systemPrompt: systemPrompt,
      userMessage: userMessage,
      maxTokens: 1500,
    );

    return ThreatIntelResult.fromJson(jsonDecode(_cleanJson(raw)));
  }

  // ── Feature 3: AI Coverage Advisor ───────────────────────────────────────

  /// Generates personalised, prioritised coverage recommendations
  /// based on the organization's profile and top risk gaps.
  Future<CoverageAdvice> generateCoverageAdvice({
    required OrganizationProfile orgProfile,
    required List<RiskGap> topGaps,
    required double currentCoverage,
    required double riskScore,
  }) async {
    const systemPrompt = '''
You are a senior cybersecurity consultant providing strategic defensive recommendations.
Your advice is specific, actionable, and tailored to the organization's context and budget constraints.
Always respond with valid JSON only — no markdown, no preamble, no code fences.
''';

    final gapsText = topGaps
        .take(8)
        .map(
          (g) =>
              '- ${g.technique.id} ${g.technique.name}: ${g.coverageLabel} (Risk: ${g.exposedRiskScore.toStringAsFixed(1)}/10)',
        )
        .join('\n');

    final userMessage =
        '''
Provide cybersecurity coverage recommendations for this organization:

Organization: ${orgProfile.name}
Sector: ${orgProfile.sector.label}
Size: ${orgProfile.orgSize.label}
Technology stack: ${orgProfile.techStackItems.map((t) => t.label).join(', ')}
Current controls: ${orgProfile.securityControlItems.map((c) => c.label).join(', ')}
Current coverage: ${currentCoverage.toStringAsFixed(1)}%
Organization risk score: ${riskScore.toStringAsFixed(1)}/100

Top uncovered ATT&CK techniques:
$gapsText

Respond with a JSON object with exactly these fields:
{
  "executiveSummary": "2-3 sentence plain-English summary suitable for a non-technical manager.",
  "priorityRecommendations": [
    {
      "priority": 1,
      "title": "Short recommendation title",
      "description": "What to do and why. Be specific to the organization's tech stack.",
      "techniquesCovered": ["T1566", "T1110"],
      "effort": "Low|Medium|High",
      "impact": "Low|Medium|High",
      "timeToImplement": "e.g. 1 day, 1 week, 1 month"
    }
  ],
  "quickWins": ["3-5 things that can be done today with no budget"],
  "estimatedRiskReduction": "How much the risk score could improve if all recommendations are followed. e.g. -15 to -25 points.",
  "nextMilestone": "The single most important milestone for this organization to reach in the next 30 days."
}

Provide exactly 5 priority recommendations, sorted by highest impact/lowest effort first.
''';

    final raw = await _call(
      systemPrompt: systemPrompt,
      userMessage: userMessage,
      maxTokens: 2000,
      cacheKey: 'coverage_${orgProfile.id}',
    );

    return CoverageAdvice.fromJson(jsonDecode(_cleanJson(raw)));
  }

  // ── Feature 4: Simulation Debrief ────────────────────────────────────────

  /// Generates a structured debrief after a simulation scenario result is recorded.
  Future<SimulationDebrief> debriefSimulation({
    required SimulationScenario scenario,
    required SimulationResult result,
    OrganizationProfile? orgProfile,
  }) async {
    const systemPrompt = '''
You are a purple team lead providing post-exercise debriefs after security simulation tests.
Your debriefs are constructive, specific, and focused on improvement.
Always respond with valid JSON only — no markdown, no preamble, no code fences.
''';

    final resultLabel = switch (result.result) {
      TestResult.passed => 'Passed',
      TestResult.failed => 'Failed',
      TestResult.partiallyPassed => 'Partially Passed',
      TestResult.notTested => 'Not Tested',
    };

    final orgCtx = orgProfile != null
        ? 'Organization sector: ${orgProfile.sector.label}. Controls: ${orgProfile.securityControlItems.map((c) => c.label).join(', ')}.'
        : '';

    final userMessage =
        '''
Generate a simulation exercise debrief:

Scenario: ${scenario.name}
Description: ${scenario.description}
Related ATT&CK Techniques: ${(scenario.relatedTechniques ?? []).join(', ')}
Objectives: ${scenario.objectives ?? 'Not specified'}
Expected Outcomes: ${scenario.expectedOutcomes ?? 'Not specified'}
Test Result: $resultLabel
Tester Observations: ${result.observations}
Tester Recommendations: ${result.recommendations}
Tested by: ${result.testedBy}
$orgCtx

Respond with a JSON object with exactly these fields:
{
  "headline": "One-sentence headline summarising the exercise outcome.",
  "whatWorked": "What defensive controls or processes worked correctly. Be specific.",
  "whatFailed": "What failed or was missing. Be specific and constructive.",
  "rootCause": "The underlying root cause of any failures.",
  "immediateActions": ["3-5 specific actions to take within 24 hours"],
  "longerTermFixes": ["2-3 strategic improvements for the next 30 days"],
  "detectionGap": "Describe any detection capability gap revealed by this exercise.",
  "mttrEstimate": "Estimated Mean Time to Respond based on the exercise. e.g. '45 minutes' or 'Unknown — no detection occurred'.",
  "score": "A score out of 10 for the defensive readiness demonstrated in this exercise.",
  "nextExercise": "Recommendation for what the next simulation exercise should test."
}
''';

    final raw = await _call(
      systemPrompt: systemPrompt,
      userMessage: userMessage,
      maxTokens: 1500,
      cacheKey: 'debrief_${scenario.id}',
    );

    return SimulationDebrief.fromJson(jsonDecode(_cleanJson(raw)));
  }

  // ── Feature 5: Natural Language Search ───────────────────────────────────

  /// Converts a natural language query into a list of relevant ATT&CK technique IDs.
  Future<List<String>> naturalLanguageSearch(String query) async {
    const systemPrompt = '''
You are a MITRE ATT&CK expert. Map natural language security queries to ATT&CK Enterprise technique IDs.
Always respond with valid JSON only — no markdown, no preamble, no code fences.
''';

    final userMessage =
        '''
Find relevant MITRE ATT&CK Enterprise technique IDs for this query:
"$query"

Respond with a JSON object:
{
  "techniqueIds": ["T1566", "T1110", "T1003"],
  "explanation": "Brief explanation of why these techniques match the query."
}

Return 3-8 most relevant technique IDs. Use real ATT&CK Enterprise IDs only (format: TXXXX or TXXXX.XXX).
''';

    final raw = await _call(
      systemPrompt: systemPrompt,
      userMessage: userMessage,
      maxTokens: 300,
      cacheKey: 'search_${query.hashCode}',
    );

    final data = jsonDecode(_cleanJson(raw));
    return List<String>.from(data['techniqueIds'] ?? []);
  }

  // ── Helpers ───────────────────────────────────────────────────────────────

  /// Clear the response cache to force fresh API calls
  void clearCache() {
    _responseCache.clear();
  }

  /// Clear cache for a specific key (e.g., when technique data is updated)
  void clearCacheKey(String key) {
    _responseCache.remove(key);
  }

  /// Get cache size for debugging
  int getCacheSize() => _responseCache.length;

  /// Remove markdown code fences if Claude accidentally adds them.
  String _cleanJson(String raw) {
    var cleaned = raw.trim();
    if (cleaned.startsWith('```')) {
      cleaned = cleaned
          .replaceFirst(RegExp(r'^```(?:json)?\s*'), '')
          .replaceFirst(RegExp(r'\s*```$'), '');
    }
    return cleaned.trim();
  }
}

// ── Custom exception ──────────────────────────────────────────────────────────

class AIServiceException implements Exception {
  final String message;
  final String? code;
  const AIServiceException(this.message, {this.code});

  @override
  String toString() => message;
}

// ── Result types ──────────────────────────────────────────────────────────────

class TechniqueExplanation {
  final String realWorldStory;
  final String whatItLooksLike;
  final String whoUsesIt;
  final String checkRightNow;
  final String topDefense;
  final String plainSummary;
  final String sectorRelevance;

  const TechniqueExplanation({
    required this.realWorldStory,
    required this.whatItLooksLike,
    required this.whoUsesIt,
    required this.checkRightNow,
    required this.topDefense,
    required this.plainSummary,
    required this.sectorRelevance,
  });

  factory TechniqueExplanation.fromJson(Map<String, dynamic> j) =>
      TechniqueExplanation(
        realWorldStory: j['realWorldStory'] ?? '',
        whatItLooksLike: j['whatItLooksLike'] ?? '',
        whoUsesIt: j['whoUsesIt'] ?? '',
        checkRightNow: j['checkRightNow'] ?? '',
        topDefense: j['topDefense'] ?? '',
        plainSummary: j['plainSummary'] ?? '',
        sectorRelevance: j['sectorRelevance'] ?? '',
      );
}

class MappedTechnique {
  final String techniqueId;
  final String techniqueName;
  final String confidence;
  final String evidence;

  const MappedTechnique({
    required this.techniqueId,
    required this.techniqueName,
    required this.confidence,
    required this.evidence,
  });

  factory MappedTechnique.fromJson(Map<String, dynamic> j) => MappedTechnique(
    techniqueId: j['techniqueId'] ?? '',
    techniqueName: j['techniqueName'] ?? '',
    confidence: j['confidence'] ?? 'low',
    evidence: j['evidence'] ?? '',
  );
}

class ThreatIntelResult {
  final String summary;
  final String threatActor;
  final List<String> targetedSectors;
  final List<MappedTechnique> mappedTechniques;
  final List<String> recommendedActions;
  final String severityLevel;
  final String alertTitle;

  const ThreatIntelResult({
    required this.summary,
    required this.threatActor,
    required this.targetedSectors,
    required this.mappedTechniques,
    required this.recommendedActions,
    required this.severityLevel,
    required this.alertTitle,
  });

  factory ThreatIntelResult.fromJson(Map<String, dynamic> j) =>
      ThreatIntelResult(
        summary: j['summary'] ?? '',
        threatActor: j['threatActor'] ?? 'Unknown',
        targetedSectors: List<String>.from(j['targetedSectors'] ?? []),
        mappedTechniques: (j['mappedTechniques'] as List? ?? [])
            .map((m) => MappedTechnique.fromJson(m as Map<String, dynamic>))
            .toList(),
        recommendedActions: List<String>.from(j['recommendedActions'] ?? []),
        severityLevel: j['severityLevel'] ?? 'Medium',
        alertTitle: j['alertTitle'] ?? 'New Threat Intelligence',
      );
}

class PriorityRecommendation {
  final int priority;
  final String title;
  final String description;
  final List<String> techniquesCovered;
  final String effort;
  final String impact;
  final String timeToImplement;

  const PriorityRecommendation({
    required this.priority,
    required this.title,
    required this.description,
    required this.techniquesCovered,
    required this.effort,
    required this.impact,
    required this.timeToImplement,
  });

  factory PriorityRecommendation.fromJson(Map<String, dynamic> j) =>
      PriorityRecommendation(
        priority: j['priority'] ?? 0,
        title: j['title'] ?? '',
        description: j['description'] ?? '',
        techniquesCovered: List<String>.from(j['techniquesCovered'] ?? []),
        effort: j['effort'] ?? 'Medium',
        impact: j['impact'] ?? 'Medium',
        timeToImplement: j['timeToImplement'] ?? 'Unknown',
      );
}

class CoverageAdvice {
  final String executiveSummary;
  final List<PriorityRecommendation> priorityRecommendations;
  final List<String> quickWins;
  final String estimatedRiskReduction;
  final String nextMilestone;

  const CoverageAdvice({
    required this.executiveSummary,
    required this.priorityRecommendations,
    required this.quickWins,
    required this.estimatedRiskReduction,
    required this.nextMilestone,
  });

  factory CoverageAdvice.fromJson(Map<String, dynamic> j) => CoverageAdvice(
    executiveSummary: j['executiveSummary'] ?? '',
    priorityRecommendations: (j['priorityRecommendations'] as List? ?? [])
        .map((r) => PriorityRecommendation.fromJson(r as Map<String, dynamic>))
        .toList(),
    quickWins: List<String>.from(j['quickWins'] ?? []),
    estimatedRiskReduction: j['estimatedRiskReduction'] ?? '',
    nextMilestone: j['nextMilestone'] ?? '',
  );
}

class SimulationDebrief {
  final String headline;
  final String whatWorked;
  final String whatFailed;
  final String rootCause;
  final List<String> immediateActions;
  final List<String> longerTermFixes;
  final String detectionGap;
  final String mttrEstimate;
  final String score;
  final String nextExercise;

  const SimulationDebrief({
    required this.headline,
    required this.whatWorked,
    required this.whatFailed,
    required this.rootCause,
    required this.immediateActions,
    required this.longerTermFixes,
    required this.detectionGap,
    required this.mttrEstimate,
    required this.score,
    required this.nextExercise,
  });

  factory SimulationDebrief.fromJson(Map<String, dynamic> j) =>
      SimulationDebrief(
        headline: j['headline'] ?? '',
        whatWorked: j['whatWorked'] ?? '',
        whatFailed: j['whatFailed'] ?? '',
        rootCause: j['rootCause'] ?? '',
        immediateActions: List<String>.from(j['immediateActions'] ?? []),
        longerTermFixes: List<String>.from(j['longerTermFixes'] ?? []),
        detectionGap: j['detectionGap'] ?? '',
        mttrEstimate: j['mttrEstimate'] ?? 'Unknown',
        score: j['score']?.toString() ?? '0',
        nextExercise: j['nextExercise'] ?? '',
      );
}
